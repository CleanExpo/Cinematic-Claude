# ╔══════════════════════════════════════════════════════════════════╗
# ║  CleanTrust YZ3500 — Multimodel Cinematic Pipeline             ║
# ║  .env.local Configuration                                      ║
# ║  Copy this file to .env.local and fill in your API keys        ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── ANTHROPIC (Claude) ─── Orchestration, Reasoning, Prompt Systems ───
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# ─── GOOGLE (Gemini) ─── Image Generation, Multimodal Analysis ───
# Get key: https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GEMINI_MODEL=gemini-2.0-flash-exp
# Gemini image model for generation (Imagen 3 via Gemini API)
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002

# ─── KLING AI ─── Cinematic Video Generation, Motion, Image-to-Video ───
# Get key: https://klingai.com/dev (sign up for API access)
# Kling uses access_key + secret_key pair for JWT authentication
KLING_ACCESS_KEY=ak-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KLING_SECRET_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KLING_API_BASE=https://api.klingai.com/v1
# Model options: kling-v1 (standard), kling-v1-5 (higher quality, slower)
KLING_MODEL=kling-v1-5
# Video duration: 5 or 10 (seconds)
KLING_DEFAULT_DURATION=5
# Video mode: std (standard) or pro (professional, 2x cost)
KLING_MODE=pro

# ─── SHOPIFY (CCW Online) ─── Product Data, Direct Checkout Links ───
# Get key: Shopify Admin > Settings > Apps > Develop apps > Create app
# Required scopes: read_products, read_product_listings
SHOPIFY_STORE_DOMAIN=ccwonline.myshopify.com
SHOPIFY_STOREFRONT_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_ADMIN_API_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# YZ3500 Product ID (get from Shopify Admin > Products > YZ3500 > URL)
SHOPIFY_YZ3500_PRODUCT_ID=
# YZ3500 Variant ID (needed for direct Add-to-Cart / Checkout URL)
# Direct checkout URL pattern: https://ccwonline.com.au/cart/{VARIANT_ID}:1
SHOPIFY_YZ3500_VARIANT_ID=

# ─── OUTPUT CONFIG ───
OUTPUT_DIR=./output
ASSET_DIR=./output/assets
VIDEO_DIR=./output/video
LOG_DIR=./output/logs

# ─── OBSERVABILITY ───
# Optional: Set to true to enable detailed pipeline tracing
ENABLE_TRACE_LOGGING=true
# Optional: Run ID prefix for asset lineage tracking
RUN_ID_PREFIX=ccw-yz3500

# ─── OPTIONAL: IMAGE HOSTING (for social media direct posting) ───
# Cloudinary, S3, or similar — for hosting generated visuals
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
